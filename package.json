{
	"name": "yoga",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"db:push": "drizzle-kit push",
		"db:detect-schedule": "tsx scripts/detect-schedule-type.ts",
		"db:migrate-search": "tsx scripts/migrate-search.ts",
		"db:migrate-search:dry": "tsx scripts/migrate-search.ts --dry-run"
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.53.4",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@types/google.maps": "^3.58.1",
		"@types/node": "^25.3.3",
		"drizzle-kit": "^0.31.9",
		"svelte": "^5.53.6",
		"svelte-check": "^4.4.4",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"vite": "^7.3.1"
	},
	"dependencies": {
		"@fontsource-variable/karla": "^5.2.8",
		"@fontsource-variable/playfair-display": "^5.2.8",
		"@libsql/client": "^0.17.0",
		"@nomideusz/svelte-calendar": "file:packages/svelte-calendar",
		"@nomideusz/svelte-i18n": "file:packages/svelte-i18n",
		"@nomideusz/svelte-search": "file:packages/svelte-search",
		"dotenv": "^17.3.1",
		"drizzle-orm": "^0.45.1",
		"resend": "^6.9.3"
	}
}
