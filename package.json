{
	"name": "yoga",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"packageManager": "pnpm@10.33.0",
	"scripts": {
		"dev": "vite dev",
		"dev:dist": "YOGA_CALENDAR_SRC=0 vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"db:push": "drizzle-kit push",
		"db:detect-schedule": "tsx scripts/detect-schedule-type.ts",
		"db:photo-placeholders": "tsx scripts/generate-photo-placeholders.ts",
		"db:migrate-search": "tsx scripts/migrate-search.ts",
		"db:migrate-search:dry": "tsx scripts/migrate-search.ts --dry-run"
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/adapter-node": "^5.5.7",
		"@sveltejs/kit": "^2.69.1",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@types/google.maps": "^3.65.2",
		"@types/node": "^25.9.4",
		"drizzle-kit": "^0.31.10",
		"svelte": "^5.56.4",
		"svelte-check": "^4.7.1",
		"tsx": "^4.23.0",
		"typescript": "^5.9.3",
		"vite": "^7.3.6"
	},
	"dependencies": {
		"@fontsource-variable/karla": "^5.2.8",
		"@fontsource-variable/playfair-display": "^5.2.8",
		"@libsql/client": "^0.17.4",
		"@nomideusz/svelte-calendar": "file:packages/svelte-calendar",
		"@nomideusz/svelte-geometrize": "file:packages/svelte-geometrize",
		"@nomideusz/svelte-i18n": "file:packages/svelte-i18n",
		"@nomideusz/svelte-search": "file:packages/svelte-search",
		"@sentry/sveltekit": "^10.63.0",
		"aws4fetch": "^1.0.20",
		"dotenv": "^17.4.2",
		"drizzle-orm": "^0.45.2",
		"lucide-svelte": "^1.0.1",
		"node-appwrite": "^26.2.0",
		"sharp": "^0.34.5"
	},
	"pnpm": {
		"supportedArchitectures": {
			"os": ["current", "linux"],
			"cpu": ["current", "x64"],
			"libc": ["current", "glibc", "musl"]
		}
	}
}
