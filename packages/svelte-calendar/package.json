{
	"name": "@nomideusz/svelte-calendar",
	"version": "0.7.5",
	"description": "A themeable Svelte 5 calendar with Day and Week views — Planner and Agenda.",
	"type": "module",
	"license": "MIT",
	"svelte": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js",
			"default": "./dist/index.js"
		},
		"./widget": "./widget/widget.js"
	},
	"files": [
		"dist",
		"widget",
		"!dist/**/*.test.*",
		"!dist/**/*.spec.*"
	],
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"package": "svelte-kit sync && svelte-package",
		"package:watch": "svelte-kit sync && svelte-package --watch",
		"build:widget": "vite build --config vite.config.widget.ts",
		"prepublishOnly": "npm run package",
		"preview": "vite preview",
		"prepare": "svelte-kit sync && svelte-package",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"peerDependencies": {
		"@chenglou/pretext": "^0.0.5",
		"svelte": "^5.0.0"
	},
	"peerDependenciesMeta": {
		"@chenglou/pretext": {
			"optional": true
		}
	},
	"devDependencies": {
		"@chenglou/pretext": "^0.0.5",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.69.1",
		"@sveltejs/package": "^2.5.8",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@types/node": "^22.20.0",
		"@vercel/analytics": "^1.6.1",
		"jsdom": "^29.1.1",
		"marked": "^17.0.6",
		"svelte": "^5.56.4",
		"svelte-check": "^4.7.1",
		"typescript": "^5.9.3",
		"vite": "^7.3.6",
		"vitest": "^4.1.9"
	},
	"dependencies": {
		"date-fns": "^4.4.0",
		"date-fns-tz": "^3.2.0"
	},
	"keywords": [
		"svelte",
		"calendar",
		"scheduler",
		"timeline",
		"week",
		"day",
		"booking",
		"svelte5"
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/nomideusz/svelte-calendar"
	},
	"homepage": "https://svelte-calendar.xyz/"
}
